{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "mm-engine-dashboard",
  "buildCommand": "cd dashboard/web && npm install && npm run build",
  "devCommand": "cd dashboard/web && npm run dev",
  "installCommand": "cd dashboard/web && npm install",
  "outputDirectory": "dashboard/web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mm-engine-dashboard.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}