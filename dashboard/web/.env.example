# Vercel / production split deploy (frontend on Vercel, API on Render/Railway)
# Set these in Vercel → Project → Settings → Environment Variables

# WebSocket — required (Vercel cannot proxy WS reliably to external backends)
VITE_WS_URL=wss://mm-engine-dashboard.onrender.com/ws/replay

# Optional — only if you skip /api rewrites in vercel.json and call API directly
# VITE_API_BASE=https://mm-engine-dashboard.onrender.com